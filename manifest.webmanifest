{
  "name": "Calculator",
  "short_name": "Calculator",
  "description": "An exact-arithmetic calculator in base twelve, with binary, decimal, dozenal and hexadecimal modes.",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "background_color": "#100c1e",
  "theme_color": "#100c1e",
  "icons": [
    { "src": "assets/favicon.svg", "sizes": "any", "type": "image/svg+xml" },
    { "src": "assets/apple-touch-icon.png", "sizes": "180x180", "type": "image/png" },
    { "src": "assets/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "assets/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "assets/icon-512-maskable.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ]
}
